# --- VPS bot config ---
PORT=3000
API_TOKEN=change-me-to-a-long-random-string

# Lovable app webhook (do not change the path)
LOVABLE_WEBHOOK_URL=https://sweet-share-joy.lovable.app/api/public/bot/webhook/message

# Copy these from the Lovable app -> VPS Bots page
WORKSPACE_ID=00000000-0000-0000-0000-000000000000
WEBHOOK_SECRET=copy-from-vps-bots-page

# Folder for Baileys multi-device auth state (persists session)
AUTH_DIR=./sessions
